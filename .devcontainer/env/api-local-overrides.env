# Local infrastructure values — overrides BWS-populated values for local containers
#
# General
API_VERSION=0.0.1
NODE_ENV=dev
#
# Postgres (local container)
KK_DB_HOST=postgres
KK_DB_PORT=5432
KK_DB_USERNAME=postgres
KK_DB_PASSWORD=postgres
KK_DB_DATABASE=krakenkey
KK_DB_LOGGING=true
KK_DB_SYNCHRONIZE=true
KK_DB_SSL=false
#
# Redis (local container)
KK_BULLMQ_HOST=redis
KK_BULLMQ_PORT=6379
KK_BULLMQ_PASSWORD=
#
# DNS Provider
DNS_PROVIDER=route53
AWS_REGION=us-east-1
#
# Auth (remote Authentik instance)
KK_AUTHENTIK_DOMAIN=auth-dev.krakenkey.io
KK_AUTHENTIK_ENROLLMENT_SLUG=krakenkey-enrollment
KK_AUTHENTIK_ISSUER_URL=https://auth-dev.krakenkey.io/application/o/krakenkey/
KK_AUTHENTIK_CLIENT_ID=krakenkey-backend
KK_AUTHENTIK_REDIRECT_URI=https://app-dev.krakenkey.io/auth/callback
KK_AUTHENTIK_POST_ENROLLMENT_REDIRECT=https://app-dev.krakenkey.io/auth/login
#
# Domains
KK_API_DOMAIN=api-dev.krakenkey.io
KK_APP_DOMAIN=app-dev.krakenkey.io
KK_API_PORT=8080
KK_WEB_DOMAIN=dev.krakenkey.io
#
# Stripe (test keys for local dev)
KK_STRIPE_SECRET_KEY=
KK_STRIPE_WEBHOOK_SECRET=
KK_STRIPE_PRICE_STARTER=
KK_STRIPE_PRICE_TEAM=
KK_STRIPE_PRICE_BUSINESS=
KK_STRIPE_PRICE_ENTERPRISE=
