# Local infrastructure values — overrides BWS-populated values for local containers
#
# General
API_VERSION=0.0.1
NODE_ENV=dev
#
# Postgres (local container)
TYPEORM_HOST=postgres
TYPEORM_PORT=5432
TYPEORM_USERNAME=postgres
TYPEORM_PASSWORD=postgres
TYPEORM_DATABASE=krakenkey
TYPEORM_LOGGING=true
TYPEORM_SYNCHRONIZE=true
TYPEORM_SSL=false
#
# Redis (local container)
BULLMQ_HOST=redis
BULLMQ_PORT=6379
BULLMQ_PASSWORD=
#
# DNS Provider
DNS_PROVIDER=route53
AWS_REGION=us-east-1
#
# Auth (remote Authentik instance)
AUTHENTIK_DOMAIN=auth-dev.krakenkey.io
AUTHENTIK_ENROLLMENT_SLUG=krakenkey-enrollment
AUTHENTIK_ISSUER_URL=https://auth-dev.krakenkey.io/application/o/krakenkey-backend/
AUTHENTIK_CLIENT_ID=krakenkey-backend
AUTHENTIK_REDIRECT_URI=https://dev.krakenkey.io/auth/callback
AUTHENTIK_POST_ENROLLMENT_REDIRECT=https://dev.krakenkey.io/auth/login
#
# Domains
KK_API_DOMAIN=api-dev.krakenkey.io
KK_API_PORT=8080
KK_WEB_DOMAIN=dev.krakenkey.io
